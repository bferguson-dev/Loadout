<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loadout"
        Height="720" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

  <DockPanel LastChildFill="True">

    <!-- Top bar -->
    <Border DockPanel.Dock="Top" Background="#2D2D2D"
            Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="#3A3A3A">
      <DockPanel>
        <Button x:Name="BtnSettings"    Content="Settings"
                DockPanel.Dock="Right"
                Padding="10,4" Margin="0,0,0,0" VerticalAlignment="Center"/>
        <Button x:Name="BtnFontLarger"  Content="T+"
                DockPanel.Dock="Right"
                Padding="8,4" Margin="0,0,6,0" VerticalAlignment="Center"/>
        <Button x:Name="BtnFontSmaller" Content="T-"
                DockPanel.Dock="Right"
                Padding="8,4" Margin="0,0,4,0" VerticalAlignment="Center"/>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="Loadout" FontSize="30" FontWeight="Bold"
                     Foreground="White"/>
          <TextBlock x:Name="LblVersion" Text="v1.0.0" FontSize="12"
                     Foreground="#888888" Margin="8,6,0,0" VerticalAlignment="Bottom"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Status bar (very bottom) -->
    <Border DockPanel.Dock="Bottom" Background="#252525"
            Padding="10,4" BorderThickness="0,1,0,0" BorderBrush="#3A3A3A">
      <TextBlock x:Name="StatusBar" Text="Ready"
                 Foreground="#777777" FontSize="22" FontFamily="Consolas"/>
    </Border>

    <!-- Progress area (above status bar) -->
    <Border DockPanel.Dock="Bottom" Background="#2D2D2D"
            Padding="10,8" BorderThickness="0,1,0,0" BorderBrush="#3A3A3A">
      <StackPanel>
        <DockPanel Margin="0,0,0,4">
          <TextBlock x:Name="LblProgressItem" Text="Item:" FontSize="22"
                     Foreground="#888888" VerticalAlignment="Center" Width="72"/>
          <ProgressBar x:Name="ProgressItem" Height="16" Value="0" Maximum="100"/>
        </DockPanel>
        <DockPanel>
          <TextBlock x:Name="LblProgressOverall" Text="Total:" FontSize="22"
                     Foreground="#888888" VerticalAlignment="Center" Width="72"/>
          <ProgressBar x:Name="ProgressOverall" Height="16" Value="0" Maximum="100"/>
        </DockPanel>
      </StackPanel>
    </Border>

    <!-- Bottom button bar (above progress) -->
    <Border DockPanel.Dock="Bottom" Background="#2D2D2D"
            Padding="10,8" BorderThickness="0,1,0,0" BorderBrush="#3A3A3A">
      <DockPanel>
        <!-- Commit on far right -->
        <Button x:Name="BtnCommit" Content="Commit" DockPanel.Dock="Right"
                Padding="14,4" Margin="6,0,0,0"
                Background="#0078D4" Foreground="White" FontWeight="SemiBold"/>
        <StackPanel Orientation="Horizontal">
          <Button x:Name="BtnScan"                Content="Scan"                  Padding="10,4" Margin="0,0,6,0"/>
          <Separator Width="1" Margin="4,2,10,2" Background="#555555"/>
          <Button x:Name="BtnSelectAll"           Content="Select All"            Padding="10,4" Margin="0,0,6,0"/>
          <Button x:Name="BtnDeselectAll"         Content="Deselect All"          Padding="10,4" Margin="0,0,6,0"/>
          <Separator Width="1" Margin="4,2,10,2" Background="#555555"/>
          <Button x:Name="BtnSelectAllUpdates"    Content="Select All Updates"    Padding="10,4" Margin="0,0,6,0"/>
          <Button x:Name="BtnDeselectAllUpdates"  Content="Deselect All Updates"  Padding="10,4" Margin="0,0,6,0"/>
          <Separator Width="1" Margin="4,2,10,2" Background="#555555"/>
          <Button x:Name="BtnBuildUsb"            Content="Build USB Kit"         Padding="10,4" Margin="0,0,6,0"/>
          <Separator Width="1" Margin="4,2,10,2" Background="#555555"/>
          <Button x:Name="BtnAddCustomApp"        Content="Add App"               Padding="10,4" Margin="0,0,6,0"/>
          <Button x:Name="BtnManageApps"          Content="Manage Apps"           Padding="10,4" Margin="0,0,6,0"/>
          <Button x:Name="BtnBackup"              Content="Import/Export"         Padding="10,4"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Main content: app checklist (left) + log panel (right) -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" MinWidth="250"/>
        <ColumnDefinition Width="3"/>
        <ColumnDefinition Width="3*" MinWidth="200"/>
      </Grid.ColumnDefinitions>

      <!-- Left: categorized app checklist -->
      <DockPanel Grid.Column="0">
        <!-- Column headers -->
        <Border DockPanel.Dock="Top" Background="#252525"
                Padding="10,4,12,4" BorderThickness="0,0,0,1" BorderBrush="#3A3A3A">
          <DockPanel>
            <!-- Spacer matches the scrollbar width so LblUpdateCol aligns over UpdateCb -->
            <Border DockPanel.Dock="Right" Width="{x:Static SystemParameters.VerticalScrollBarWidth}"/>
            <TextBlock x:Name="LblUpdateCol" DockPanel.Dock="Right" Text="Update" FontSize="20"
                       Foreground="#888888" Width="80" TextAlignment="Center"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="LblInstallCol" Text="Install / Uninstall" FontSize="20"
                       Foreground="#888888" VerticalAlignment="Center"/>
          </DockPanel>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Visible"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel x:Name="AppListPanel" Margin="10,8,12,8"/>
        </ScrollViewer>
      </DockPanel>

      <!-- Column splitter -->
      <GridSplitter Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    Background="#3A3A3A"
                    ShowsPreview="True"/>

      <!-- Right: live log panel (RichTextBox for per-level color) -->
      <RichTextBox x:Name="LogPanel"
                   Grid.Column="2"
                   IsReadOnly="True"
                   VerticalScrollBarVisibility="Auto"
                   HorizontalScrollBarVisibility="Disabled"
                   Background="#141414"
                   Foreground="#CCCCCC"
                   FontFamily="Consolas"
                   FontSize="11"
                   Padding="4"
                   BorderThickness="0"/>

    </Grid>

  </DockPanel>

</Window>
