{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loadout Manifest",
  "description": "Schema for Loadout manifest.json",
  "type": "object",
  "required": ["version", "lastUpdated", "apps"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "Manifest schema version (semver)",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "lastUpdated": {
      "type": "string",
      "description": "Date the manifest was last updated (YYYY-MM-DD)",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "preferX64": {
      "type": "boolean"
    },
    "apps": {
      "type": "array",
      "description": "List of installable apps",
      "minItems": 1,
      "items": { "$ref": "#/definitions/app" }
    }
  },
  "definitions": {
    "app": {
      "type": "object",
      "required": [
        "id",
        "displayName",
        "description",
        "category",
        "isPrerequisite",
        "dependencies",
        "requiresReboot",
        "requiresElevation",
        "includeInUSBKit"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique app identifier (kebab-case)",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "isPrerequisite": {
          "type": "boolean"
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requiresReboot": {
          "type": "boolean"
        },
        "requiresElevation": {
          "type": "boolean"
        },
        "includeInUSBKit": {
          "type": "boolean"
        },
        "arm64Available": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        },
        "silentArgs": {
          "type": "string"
        },
        "wingetId": {
          "type": "string",
          "minLength": 3,
          "description": "Winget package ID (Publisher.Package)"
        },
        "psGalleryModule": {
          "type": "string",
          "minLength": 1,
          "description": "PowerShell Gallery module name"
        },
        "vscodeExtensionId": {
          "type": "string",
          "minLength": 1,
          "description": "VS Code Marketplace extension ID (publisher.extension)"
        },
        "chocolateyId": {
          "type": "string",
          "minLength": 1
        },
        "directDownload": {
          "$ref": "#/definitions/directDownload"
        },
        "wslDistroName": {
          "type": "string"
        },
        "packageManager": {
          "type": "string",
          "enum": ["apt", "dnf", "yum", "pacman", "zypper"]
        },
        "postInstallPackages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requiresUserSetup": {
          "type": "boolean"
        },
        "windowsFeatureMethod": {
          "type": "string",
          "enum": ["Enable-WindowsOptionalFeature", "Add-WindowsCapability"]
        },
        "windowsFeatureName": {
          "type": "string"
        },
        "registryPath": {
          "type": "string"
        },
        "registryName": {
          "type": "string"
        },
        "registryValue": {},
        "registryType": {
          "type": "string",
          "enum": ["DWORD", "QWORD", "String", "ExpandString", "MultiString", "Binary"]
        },
        "postInstallOnly": {
          "type": "boolean"
        },
        "postInstallCommands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "prereqCheck": {
          "type": "string"
        }
      }
    },
    "directDownload": {
      "type": "object",
      "required": ["url"],
      "additionalProperties": true,
      "properties": {
        "url": {
          "type": "string",
          "minLength": 8
        },
        "urlTemplate": {
          "type": "string",
          "description": "URL with {version} placeholder — used by manifest-update CI"
        },
        "versionCheckUrl": {
          "type": "string"
        },
        "versionCheckMethod": {
          "type": "string",
          "enum": ["json-path", "regex", "html-regex", "github-release"]
        },
        "versionCheckExpression": {
          "type": "string"
        },
        "installedVersionPath": {
          "type": "string"
        },
        "checksumUrl": {
          "type": "string"
        },
        "checksumAlgorithm": {
          "type": "string",
          "enum": ["sha256", "sha512", "md5"]
        }
      }
    }
  }
}
